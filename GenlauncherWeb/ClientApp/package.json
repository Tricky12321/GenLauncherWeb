{
  "name": "GenLauncher_Frontend",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "build.prod": "node --max_old_space_size=16384 ng build --configuration production && tar -zcvf archive.tar.gz dist/*",
    "start": "ng serve",
    "build": "node --max_old_space_size=16384 ./node_modules/@angular/cli/bin/ng build --configuration production",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "build:stats": "ng build --stats-json",
    "analyze": "webpack-bundle-analyzer dist/stats-es2015.json"
  },
  "private": true,
  "engines": {
    "node": ">=22.22.3"
  },
  "dependencies": {
    "@angular/cdk": "22.0.0",
    "@angular/common": "22.0.1",
    "@angular/compiler": "22.0.1",
    "@angular/core": "22.0.1",
    "@angular/elements": "22.0.1",
    "@angular/forms": "22.0.1",
    "@angular/localize": "22.0.1",
    "@angular/platform-browser": "22.0.1",
    "@angular/platform-browser-dynamic": "22.0.1",
    "@angular/router": "22.0.1",
    "bootstrap": "5.2.3",
    "ngx-toastr": "20.0.5",
    "rxjs": "7.8.1",
    "tslib": "2.3.1",
    "typescript": "6.0.3",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.1",
    "@angular/cli": "22.0.1",
    "@angular/compiler-cli": "22.0.1",
    "@angular/language-service": "22.0.1",
    "@types/jasmine": "4.3.1",
    "@types/jasminewd2": "2.0.10",
    "@types/node": "22.0.0",
    "jasmine-core": "4.5.0",
    "jasmine-spec-reporter": "7.0.0",
    "karma": "6.4.1",
    "karma-chrome-launcher": "3.1.1",
    "karma-coverage-istanbul-reporter": "3.0.3",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "1.7.0",
    "webpack-bundle-analyzer": "4.7.0"
  },
  "optionalDependencies": {
    "eslint": "8.56.0",
    "ts-node": "10.9.2"
  }
}
